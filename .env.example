# Database
DATABASE_URL=postgresql://user:password@localhost:5432/research_platform

# Redis
REDIS_URL=redis://localhost:6379

# API Keys (use your own)
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
EXA_API_KEY=exa-...

# AWS Bedrock (for Claude, Llama, Mistral models)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Stripe (if using billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (for Indian billing - optional in dev)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=whsec_...
STRIPE_DEVELOPER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Server
PORT=3000
NODE_ENV=development

# Security
ALLOWED_ORIGINS=http://localhost:3001

# Clouflare (for proxy rotation)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
