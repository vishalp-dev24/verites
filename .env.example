# Environment Configuration for Veritas

# Application
NODE_ENV=development
PORT=3000

# Database
DB_USER=veritas
DB_PASSWORD=veritas_secret
DB_NAME=veritas
DATABASE_URL=postgresql://veritas:veritas_secret@localhost:5432/veritas

# Redis
REDIS_URL=redis://localhost:6379

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# -----------------------------------------------------------------------------
# REQUIRED: API Keys for LLM providers (pick one or both)
# -----------------------------------------------------------------------------

# OpenAI (primary provider)
OPENAI_API_KEY=sk-your-openai-key-here

# AWS Bedrock (backup/alternative provider)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Optional: Search Providers (enhances research quality)
# -----------------------------------------------------------------------------

# Tavily AI Search (recommended)
TAVILY_API_KEY=tvly-your-key-here

# Serper.dev (Google Search API)
# SERPER_API_KEY=your-serper-key-here

# -----------------------------------------------------------------------------
# Optional: Billing (Razorpay - India only)
# -----------------------------------------------------------------------------

# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# -----------------------------------------------------------------------------
# Session & Cache Configuration
# -----------------------------------------------------------------------------

SESSION_TTL_DAYS=30
CACHE_TTL_MINUTES=60

# -----------------------------------------------------------------------------
# Rate Limiting & Resource Limits
# -----------------------------------------------------------------------------

MAX_REQUESTS_PER_MINUTE=100
MAX_CONCURRENT_WORKERS=50
