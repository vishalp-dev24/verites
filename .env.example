# Environment Configuration for Veritas

# Application
NODE_ENV=production
PORT=3000

# Database
DB_USER=veritas
DB_PASSWORD=
DB_NAME=veritas
DATABASE_URL=postgresql://veritas:replace-with-db-password@localhost:5432/veritas

# Redis
# REDIS_URL must use the same password as REDIS_PASSWORD.
REDIS_PASSWORD=
REDIS_URL=redis://:replace-with-redis-password@localhost:6379

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Admin routes
# Required in production.
ADMIN_API_TOKEN=

# Dashboard/API public origins
API_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
DASHBOARD_API_KEY=
DASHBOARD_USERNAME=veritas-admin
DASHBOARD_PASSWORD=
DASHBOARD_PROXY_REQUESTS_PER_MINUTE=60

# -----------------------------------------------------------------------------
# REQUIRED: API Keys for LLM providers (pick one or both)
# -----------------------------------------------------------------------------

# OpenAI (primary provider)
OPENAI_API_KEY=

# AWS Bedrock (backup/alternative provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# REQUIRED in production: Search Providers (pick Tavily or Exa)
# -----------------------------------------------------------------------------

# Tavily AI Search (recommended)
TAVILY_API_KEY=

# Exa AI Search fallback
# EXA_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Billing (Razorpay - India only)
# -----------------------------------------------------------------------------

# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# -----------------------------------------------------------------------------
# Session & Cache Configuration
# -----------------------------------------------------------------------------

SESSION_TTL_DAYS=30
CACHE_TTL_MINUTES=60

# -----------------------------------------------------------------------------
# Rate Limiting & Resource Limits
# -----------------------------------------------------------------------------

MAX_REQUESTS_PER_MINUTE=100
MAX_PREAUTH_REQUESTS_PER_MINUTE=100
MAX_AUTHENTICATED_REQUESTS_PER_MINUTE=100
MAX_CONCURRENT_WORKERS=50
