{
  "name": "@veritas/sdk",
  "version": "1.0.0",
  "description": "JavaScript SDK for using Veritas research in AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "veritas",
    "research",
    "ai",
    "mcp",
    "api",
    "sdk",
    "langchain",
    "agent-tools"
  ],
  "author": "Veritas",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
