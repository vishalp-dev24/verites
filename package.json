{
  "name": "veritas",
  "version": "1.0.0",
  "description": "Research backend and tool interface for AI agents",
  "main": "dist/app.js",
  "type": "module",
  "workspaces": [
    "sdk/javascript",
    "dashboard"
  ],
  "scripts": {
    "prebuild": "prisma generate",
    "build": "tsc && tsc-alias",
    "dev": "tsx watch src/app.ts",
    "start": "node dist/app.js",
    "mcp": "node dist/mcp.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/bootstrap.mjs",
    "db:bootstrap": "node prisma/bootstrap.mjs",
    "test": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "build:sdk": "npm run build -w @veritas/sdk",
    "build:dashboard": "npm run build -w @veritas/dashboard",
    "dev:dashboard": "npm run dev -w @veritas/dashboard"
  },
  "prisma": {
    "seed": "node prisma/bootstrap.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "morgan": "^1.10.0",
    "openai": "^4.25.0",
    "puppeteer": "^24.43.0",
    "razorpay": "^2.9.6",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.56.0",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      ".": "16.2.6",
      "postcss": "8.5.14"
    },
    "eslint-config-next": "16.2.6",
    "@next/eslint-plugin-next": "16.2.6",
    "postcss": "8.5.14"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "keywords": [
    "research",
    "ai",
    "mcp",
    "agents",
    "langchain",
    "agent-tools"
  ],
  "license": "MIT"
}
